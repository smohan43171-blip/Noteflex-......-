# .npmrc — NoteFlex package manager config

# Use exact versions — no accidental minor bumps in CI/EAS
save-exact=true

# Enforce the React version across all packages (prevents duplicate React installs)
# This ensures react-native-sketch-canvas and other libs resolve to React 18
legacy-peer-deps=true

# Hoist all packages to node_modules root (required for React Native metro bundler)
shamefully-hoist=true

# Lock React to 18.x — any package trying to install React 17 or 19 will fail
# EAS reads this during `npm install` on the build server
overrides.react=18.2.0
overrides.react-dom=18.2.0

# Minimum node version for EAS builders
engine-strict=true
